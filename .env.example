#
# HOSTINGER Environment variables (NO quotes on password):
#   NODE_ENV=production
#   DB_HOST=127.0.0.1
#   DB_NAME=u227950127_ashburndcs
#   DB_USER=u227950127_ashburn
#   DB_PASSWORD=Ashburndcs123!@#
#   FRONTEND_URL=https://ashburndcs.com,https://www.ashburndcs.com


PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ashburndcs
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

ADMIN_EMAIL=ashburndcsolutions@gmail.com
ADMIN_PASSWORD=Ashburn@123
ADMIN_NAME=Admin
ADMIN_EMAILS=ashburndcsolutions@gmail.com

JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000

EMAIL_VERIFY_EXPIRY_HOURS=24
RESET_PASSWORD_EXPIRY_HOURS=1

# Nodemailer (Gmail) — use a Google App Password, not your normal login password
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=ADCS Tech <your-email@gmail.com>
MAIL_TO=ashburndcsolutions@gmail.com
ADMIN_NOTIFY_EMAIL=ashburndcsolutions@gmail.com

STRIPE_SECRET_KEY=
