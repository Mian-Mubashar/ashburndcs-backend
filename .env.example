# ═══════════════════════════════════════════════════════════
# Ashburn DCS Backend — .env.example
# Copy to .env | Keep LOCAL active, PRODUCTION commented until live
# ═══════════════════════════════════════════════════════════

# ─────────────── LOCAL (active) ───────────────
PORT=5000

DB_NAME=ashburndcs
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql

ADMIN_EMAIL=ashburndcsolutions@gmail.com
ADMIN_PASSWORD=Ashburn@123
ADMIN_NAME=Admin
ADMIN_EMAILS=ashburndcsolutions@gmail.com

JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000

EMAIL_VERIFY_EXPIRY_HOURS=24
RESET_PASSWORD_EXPIRY_HOURS=1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=ADCS Tech <your-email@gmail.com>
MAIL_TO=ashburndcsolutions@gmail.com
ADMIN_NOTIFY_EMAIL=ashburndcsolutions@gmail.com

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ─────────────── PRODUCTION (commented — enable on live server) ───────────────
# PORT=5000
#
# DB_NAME=ashburndcs
# DB_USER=your_production_db_user
# DB_PASSWORD=your_production_db_password
# DB_HOST=your_production_db_host
# DB_PORT=3306
# DB_DIALECT=mysql
#
# ADMIN_EMAIL=admin@ashburndcs.com
# ADMIN_PASSWORD=ChangeThisStrongPassword123!
# ADMIN_NAME=Admin
# ADMIN_EMAILS=admin@ashburndcs.com
#
# JWT_SECRET=replace_with_long_random_secret_in_production
# FRONTEND_URL=https://ashburndcs.com
#
# EMAIL_VERIFY_EXPIRY_HOURS=24
# RESET_PASSWORD_EXPIRY_HOURS=1
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-production-email@gmail.com
# SMTP_PASS=your-production-app-password
# MAIL_FROM=ADCS Tech <noreply@ashburndcs.com>
# MAIL_TO=info@ashburndcs.com
# ADMIN_NOTIFY_EMAIL=admin@ashburndcs.com
#
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
